bash

cat << 'EOF'
{
  "version": 2,
  "builds": [
    {
      "src": "public/index.html",
      "use": "@vercel/static"
    },
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/quote",
      "dest": "/api/quote.js"
    },
    {
      "src": "/api/chart",
      "dest": "/api/chart.js"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.html"
    }
  ]
}
EOF
Ausgabe

